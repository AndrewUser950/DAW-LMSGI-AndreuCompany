{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["customer"],
  "properties": {
    "customer": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cust_id", "fed_id"],
        "properties": {
          "cust_id": { "type": "integer" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "fed_id": { "type": "string" },
          "postal_code": { "type": "string" },
          "state": {
            "type": "string",
            "enum": ["MA", "NH", "RI", "VE", "CN", "NY"]
          },

          "individual": {
            "type": "object",
            "required": ["first_name_ind", "last_name_ind"],
            "properties": {
              "first_name_ind": { "type": "string" },
              "last_name_ind": { "type": "string" },
              "birth_date": {
                "type": "string",
                "format": "date"
              }
            }
          },

          "business": {
            "type": "object",
            "required": ["name", "state_id", "officer"],
            "properties": {
              "name": { "type": "string" },
              "state_id": { "type": "string" },
              "incorp_date": {
                "type": "string",
                "format": "date"
              },
              "officer": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "officer_id",
                    "first_name_off",
                    "last_name_off"
                  ],
                  "properties": {
                    "officer_id": { "type": "integer" },
                    "end_date": {
                      "type": "string",
                      "format": "date"
                    },
                    "first_name_off": { "type": "string" },
                    "last_name_off": { "type": "string" },
                    "start_date": {
                      "type": "string",
                      "format": "date"
                    },
                    "title": {
                      "type": "string",
                      "enum": ["President", "CEO"]
                    }
                  }
                }
              }
            }
          }
        },
        "oneOf": [
          { "required": ["individual"] },
          { "required": ["business"] }
        ]
      }
    }
  }
}
